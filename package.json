{
  "name": "miniapp-audit",
  "version": "0.1.0",
  "description": "小程序上线前安全检查工具",
  "keywords": [
    "miniapp",
    "wechat",
    "security",
    "audit",
    "scanner"
  ],
  "homepage": "https://github.com/your-name/miniapp-audit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-name/miniapp-audit.git"
  },
  "bugs": {
    "url": "https://github.com/your-name/miniapp-audit/issues"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "miniapp-audit": "./bin/miniapp-audit"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:cli": "tsc -p tsconfig.cli.json",
    "clean": "rm -rf dist .next",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint src app",
    "build": "npm run build:cli && next build",
    "dev": "next dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepack": "npm run build:cli"
  },
  "dependencies": {},
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
